__pycache__/
*.py[cod]
.venv/
streamlit_stdout.log
streamlit_stderr.log
.streamlit/*
!.streamlit/config.toml

# Keep directory structure, but do not publish research images or generated data.
data/images/*
data/annotations/*
data/exports/*
data/exports/yolo_labels/*
data/dataset/*
data/patches/*
data/patches/images/*
data/clam/*
!data/images/.gitkeep
!data/annotations/.gitkeep
!data/exports/.gitkeep
!data/exports/yolo_labels/
!data/exports/yolo_labels/.gitkeep
!data/dataset/
!data/dataset/images/
!data/dataset/labels/
!data/dataset/images/.gitkeep
!data/dataset/labels/.gitkeep
!data/patches/
!data/patches/images/
!data/patches/images/.gitkeep
!data/clam/
!data/clam/.gitkeep
!data/clam/coords/
!data/clam/coords/.gitkeep
!data/clam/features/
!data/clam/features/.gitkeep
